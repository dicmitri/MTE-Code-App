{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "cms": "concurrently --kill-others-on-fail --names app,cms \"npm run dev\" \"npm run cms:proxy\"",
    "cms:proxy": "decap-server",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "verify:code-migration": "node scripts/verify-code-migration.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "test": "node --test",
    "check": "npm run validate:data && npm test && npm run lint && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.7.284",
    "pdfmake": "^0.3.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pdfmake": "^0.3.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "decap-server": "^3.9.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
